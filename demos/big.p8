pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- big.p8
-- demos big sprites via the
-- 'big' flag and extra/custom
-- collision actions
#include ../flutton.p8
g=.1
mapw=16
maph=16
big=true

extra_col={
 [3]=function(t,e)
  e.vy-=2.75
  e.l-=5
  t.del=nil
 end
}
